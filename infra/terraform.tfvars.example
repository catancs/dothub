# Copy this file to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored, so your real values stay out of version control.

# The domain that will point at the instance (nginx server_name and BASE_URL).
domain = "dothub.example.com"

# Your public IP as a /32, for SSH access.
# Find it with: curl -s https://checkip.amazonaws.com
admin_cidr = "1.2.3.4/32"

# Paste the CONTENTS of your SSH public key here, for example the single line
# inside ~/.ssh/id_ed25519.pub. This is the public key, never the private key.
ssh_public_key = "ssh-ed25519 AAAAC3NzaC1lZDI1... you@example.com"

# Region defaults to eu-central-1. Uncomment to override.
# region = "eu-central-1"
