# Replace dothub.nl with your domain. Caddy fetches + auto-renews the TLS cert
# once DNS points at this box; it retries until DNS resolves, so there is no
# ordering dependency between provisioning and the A-record.
dothub.nl {
    # Structured access logs for self-hosted analytics (GoAccess reads these).
    log {
        output file /var/log/caddy/access.log {
            roll_size 20MiB
            roll_keep 10
        }
        format json
    }
    reverse_proxy localhost:8000
}
